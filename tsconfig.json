{
	"extends": "astro/tsconfigs/base",
	"include": [".astro/types.d.ts", "**/*"],
	"exclude": ["dist"],
	"compilerOptions": {
		"strictNullChecks": true,
		"allowJs": true,
		"forceConsistentCasingInFileNames": true,
		"jsx": "react-jsx",
		"paths": {
			"@config/*": ["./src/config/*"],
			"@js/*": ["./src/js/*"],
			"@layouts/*": ["./src/layouts/*"],
			"@components/*": ["./src/components/*"],
			"@assets/*": ["./src/assets/*"],
			"@images/*": ["./src/assets/images/*"],
			"@videos/*": ["./src/assets/videos/*"],
			"@/*": ["./src/*"]
		}
	}
}
