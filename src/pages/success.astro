---
import Button from "../components/Button/Button.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title='success' description='message successfully submitted with contact form'>
	<section class='site-container pt-36 text-center md:pt-44'>
		<div class='mx-auto max-w-xl px-4 text-center'>
			<h1 class='h1 sorts-mill-goudy-regular'>It&apos;s in the mail!</h1>
			<p class='description staatliches-regular mt-4'>Time to kick back and put some tunes on.</p>
			<p class='description staatliches-regular mt-4'>
				Your message is on the way to us now, and we will get back to you as soon as possible.
			</p>
			<div class='staatliches-regular mt-8 flex justify-center'>
				<Button variant='primary' href='/'>Go to homepage</Button>
			</div>
		</div>
	</section>
</BaseLayout>
