---
/**
 * * Hero with background image
 * You'll want a mobile image, and a desktop image for this.
 */

import Button from "@components/Button/Button.astro";
import heroImage from "@images/hero-bg-min.jpg";
import heroImageMobile from "@images/hero-bg-min.jpg";
import { Image } from "astro:assets";
---

<section id='hero' class='relative z-10 flex min-h-[100lvh] w-full'>
	<!-- background image -->
	<div class='absolute -z-10 h-full min-h-full w-full overflow-hidden'>
		<div class='absolute inset-0 bg-black/10'></div>

		<Image
			src={heroImage}
			class='hidden h-auto min-h-full w-full object-cover object-bottom sm:block'
			alt='wedding'
			aria-hidden='true'
			loading='eager'
			height={1400}
		/>
		<Image
			src={heroImageMobile}
			class='h-auto min-h-full w-full object-cover sm:hidden'
			alt='wedding'
			aria-hidden='true'
			loading='eager'
			width={1200}
		/>
	</div>

	<!-- hero items -->
	<div class='site-container relative w-full gap-10 py-44 text-center md:py-52 md:text-left'>
		<!-- Hero text -->
		<div
			class='my-auto mr-auto max-w-[800px] flex-col rounded-2xl bg-white p-6 text-black opacity-50 shadow-2xl drop-shadow-black'>
			<h1 class='font-heading-1 staatliches-regular text-5xl md:text-7xl md:leading-tight'>
				The Noise Floor
			</h1>
			<p class='sorts-mill-goudy-regular mt-8 text-lg tracking-widest md:max-w-[550px] md:text-2xl'>
				Your home for all things guitar, drums, and music in the high desert
			</p>
		</div>
	</div>
</section>
