---
import { Image } from "astro:assets";
import bazaarFlyer from "../../assets/images/gear-bazaar-flyer.png";
---

<section id='events' class='site-container scroll-mt-10 py-8 md:py-12'>
	<h2 class='h2 text-primary-500 staatliches-regular py-4 text-center text-pretty uppercase'>
		Upcoming Events
	</h2>
	<div class='flex flex-col-reverse md:flex-row'>
		<div class='md:mt-6 md:w-2/3'>
			<h3 class='h2 staatliches-regular place-content-center py-4 text-center'>
				Gear Bazaar and Meetup
			</h3>
			<h5 class='h3 staatliches-regular place-content-center py-4 text-center'>
				July 26, 2026 | 6416 Hallee Rd. Ste. A
			</h5>
			<div class='bg-base-100 p-8 md:mt-8 md:mb-20 lg:text-lg'>
				<p class='py-2'>
					We are excited to announce that we&apos;re our first ever gear bazaar and swap meet! We
					invite you to come meet other musicians from the hi-desert and score some screaming deals
					on rare and unique gear.
				</p>
				<p class='py-2'>
					Food will be available from our friends from I Fall To Pizzas, and we&apos;ll be hanging
					out from 4pm&dash;8pm here at the newest independent music shop in the desert. Don&apos;t
					miss this very special event featuring vendors from all over the area selling unique gear
					and swapping stories&excl;
				</p>
				<p class='py-2'>
					Are you interested in selling some of your gear&quest; Get in touch via the form below or
					send us a DM, and secure your spot before they run out.
				</p>
			</div>
		</div>
		<div class='mr-auto max-w-md md:w-1/3 md:max-w-none'>
			<div class='my-auto aspect-[3/4] w-full overflow-hidden'>
				<Image
					src={bazaarFlyer}
					alt='Flyer for the July 26th Gear Bazaar at The Noise Floor'
					width={450}
					densities={[1.5, 2]}
					class='h-auto min-h-full w-full min-w-full object-cover'
				/>
			</div>
		</div>
	</div>
</section>
